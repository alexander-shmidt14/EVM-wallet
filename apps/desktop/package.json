{
  "name": "@app/desktop",
  "version": "1.0.0",
  "description": "EVM Wallet Desktop App",
  "main": "dist/main.js",
  "homepage": "./",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run build:main\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npm run build:main && npm run build:renderer && electron-builder",
    "build:main": "node esbuild.main.mjs",
    "build:renderer": "vite build",
    "electron": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --x64",
    "dist:portable": "electron-builder --win portable --x64",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "clean": "rimraf dist",
    "rebuild": "npm run clean && npm run build"
  },
  "dependencies": {
    "@ethersproject/contracts": "^5.8.0",
    "@ethersproject/hdnode": "^5.8.0",
    "@ethersproject/providers": "^5.8.0",
    "@ethersproject/shims": "^5.8.0",
    "@ethersproject/wallet": "^5.8.0",
    "@noble/curves": "^2.0.0",
    "@noble/hashes": "^2.0.0",
    "@noble/secp256k1": "^3.0.0",
    "@wallet/ui-tokens": "workspace:*",
    "@wallet/wallet-core": "workspace:*",
    "abort-controller": "^3.0.0",
    "assert": "^2.1.0",
    "axios": "^1.11.0",
    "buffer": "^6.0.3",
    "clsx": "^2.0.0",
    "constants-browserify": "^1.0.0",
    "cross-fetch": "^4.0.0",
    "crypto-browserify": "^3.12.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "ethers": "^6.8.0",
    "events": "^3.3.0",
    "form-data": "^4.0.4",
    "http": "0.0.1-security",
    "https": "^1.0.0",
    "isomorphic-fetch": "^3.0.0",
    "isomorphic-unfetch": "^4.0.2",
    "node-fetch": "^3.3.2",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^4.0.11",
    "react-icons": "^4.12.0",
    "react-router-dom": "^6.8.1",
    "react-toastify": "^9.1.3",
    "request": "^2.88.2",
    "stream-browserify": "^3.0.0",
    "tslib": "^2.8.1",
    "unfetch": "^5.0.0",
    "url": "^0.11.4",
    "util": "^0.12.5",
    "whatwg-fetch": "^3.6.20",
    "xhr2": "^0.2.1",
    "xmlhttprequest": "^1.8.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.0",
    "@types/qrcode": "^1.5.2",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.0",
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0",
    "electron-packager": "^17.1.2",
    "esbuild": "^0.27.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.31",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.3.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2",
    "vite": "^4.3.0",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.evmwallet.desktop",
    "productName": "EVM Wallet",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "sign": null,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "forceCodeSigning": false
  }
}
