# Ethereum RPC (выберите одного провайдера)
ALCHEMY_RPC_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE
# или
INFURA_RPC_MAINNET=https://mainnet.infura.io/v3/YOUR_API_KEY_HERE

# История транзакций (опционально)
ETHERSCAN_API_KEY=YOUR_API_KEY_HERE

# Входящие ERC-20 (опционально)
# CSV whitelist контрактов для incoming токенов.
# Если пусто — по умолчанию используется только MMA токен.
INCOMING_ERC20_WHITELIST=0xcA82d24A97b33F2d5826575f77fdc8Bdb82FC580

# UI / Брендинг
APP_NAME=EVM Wallet
PRIMARY_COLOR=#0B0F1F
FIAT=USD

# Предустановленный токен (опционально)
PINNED_TOKEN_ADDRESS=0xa0b86a33e6776636c4f6df81a7b06eba6ae67863
PINNED_TOKEN_SYMBOL=CTT
PINNED_TOKEN_DECIMALS=18
